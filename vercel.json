{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": true,
  "redirects": [
    { "source": "/corporate", "destination": "/services/corporate-events/", "permanent": true },
    { "source": "/weddings", "destination": "/services/weddings/", "permanent": true },
    { "source": "/birthdays", "destination": "/services/private-parties/", "permanent": true },
    { "source": "/our-props", "destination": "/work/", "permanent": true },
    { "source": "/packages", "destination": "/#pricing", "permanent": true },
    { "source": "/influencer-package", "destination": "/#pricing", "permanent": true },
    { "source": "/polaroid-package", "destination": "/#pricing", "permanent": true },
    { "source": "/customer-login", "destination": "/support/", "permanent": true },
    { "source": "/customer-dashboard", "destination": "/support/", "permanent": true },
    { "source": "/customer-cabinet", "destination": "/support/", "permanent": true },
    { "source": "/:year(20\\d{2})/:path*", "destination": "/blog/", "permanent": true },
    { "source": "/wp-sitemap:suffix(.*).xml", "destination": "/sitemap.xml", "permanent": true },
    { "source": "/feed", "destination": "/blog/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://tiles.openfreemap.org; connect-src 'self' https://tiles.openfreemap.org https://formspree.io; worker-src blob:; font-src 'self' data:; form-action 'self' https://formspree.io; frame-ancestors 'self'; base-uri 'self'"
        }
      ]
    }
  ]
}
